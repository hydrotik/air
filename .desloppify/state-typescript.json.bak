    "review::.::holistic::abstraction_fitness::hidden_config_io_factory::dc96bc08": {
      "id": "review::.::holistic::abstraction_fitness::hidden_config_io_factory::dc96bc08",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "The SDK's config-driven RAG factory hides ambient filesystem I/O behind a helper that reads like a pure constructor.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "src/sdk/rag.ts",
          "src/shared/config.ts",
          "src/server/index.ts",
          "src/server/cli.ts"
        ],
        "evidence": [
          "`createRagTracersFromConfig()` in `src/sdk/rag.ts` unconditionally calls `loadConfig()`, which walks parent directories from `process.cwd()` and logs to the console from `src/shared/config.ts`.",
          "The same config-loading policy is also embedded in the server boot path (`src/server/index.ts` and `src/server/cli.ts`), so config discovery is duplicated across runtime boundaries instead of being an explicit dependency passed in once."
        ],
        "suggestion": "Split config discovery from object construction: keep `loadConfig()` as an explicit server/CLI concern, and make the SDK factory accept `RagProviderConfig[]` or an `AirConfig` object directly. If a convenience loader is kept, name it as an I/O helper and isolate its logging so callers can opt into that behavior.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-02T01:44:24+00:00",
      "last_seen": "2026-03-02T01:44:24+00:00",
