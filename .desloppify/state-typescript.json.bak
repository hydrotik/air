    "review::.::holistic::cross_module_architecture::telemetry_hook_as_dashboard_service_locator::caed38ae": {
      "id": "review::.::holistic::cross_module_architecture::telemetry_hook_as_dashboard_service_locator::caed38ae",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "`useTelemetry()` has become a subsystem-wide service locator that couples every dashboard feature to one hook surface.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "src/dashboard/hooks/useTelemetry.ts",
          "src/dashboard/visualizations/McpStatsPanel.tsx",
          "src/dashboard/visualizations/RagStatsPanel.tsx"
        ],
        "evidence": [
          "`src/dashboard/hooks/useTelemetry.ts` owns live event transport plus a long list of feature-specific fetchers: sessions, config, context, MCP stats/timeseries, RAG stats/timeseries, latency, cost, evals, prompts, and drift.",
          "The hook returns all of these functions from one object, making feature additions depend on widening a central API instead of adding a new feature module.",
          "`McpStatsPanel` and `RagStatsPanel` are leaf components that only need one slice of data each, but the current architecture offers no narrower MCP- or RAG-specific boundary; those features only exist as methods hanging off the general telemetry hook."
        ],
        "suggestion": "Refactor `useTelemetry()` into a small live-session transport/core hook and feature-scoped dashboard clients or hooks such as `useMcpStats`, `useRagStats`, and `useSessionContext`, so each panel depends on its own boundary instead of a central omnibus service.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-02T01:44:24+00:00",
      "last_seen": "2026-03-02T01:44:24+00:00",
