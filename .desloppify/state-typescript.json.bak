      "id": "review::.::holistic::abstraction_fitness::dashboard_hook_is_a_pass_through_bag::c733bd4a",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "useTelemetry adds a boundary but leaves all orchestration complexity in the page",
      "detail": {
