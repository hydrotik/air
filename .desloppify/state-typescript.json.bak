    "review::.::holistic::cross_module_architecture::shared_events_god_boundary::ca5fca37": {
      "id": "review::.::holistic::cross_module_architecture::shared_events_god_boundary::ca5fca37",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "`src/shared/events.ts` collapses protocol types, dashboard DTOs, and pricing logic into one shared dependency hub.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "src/shared/events.ts",
          "src/dashboard/hooks/useTelemetry.ts"
        ],
        "evidence": [
          "`src/shared/events.ts` defines low-level telemetry event unions, dashboard WebSocket message types, session summary read models, and also exports `MODEL_PRICING` plus `computeCost()` in the same module.",
          "`src/dashboard/hooks/useTelemetry.ts` imports `TelemetryEvent`, `SessionSummary`, and `DashboardMessage` from that file, so dashboard read-side code is forced through the same module that also owns pricing/business logic unrelated to WebSocket consumption.",
          "The blind packet already marks `src/shared/events.ts` as a 17-importer god module, which is consistent with this boundary collapse becoming the default dependency for unrelated concerns."
        ],
        "suggestion": "Split `src/shared/events.ts` by ownership: keep raw telemetry event protocol types in one module, move dashboard transport/read models into a dashboard-facing contract module, and move pricing tables/helpers into a separate pricing utility so changes in one concern do not ripple through all importers.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-02T01:44:24+00:00",
      "last_seen": "2026-03-02T01:44:24+00:00",
