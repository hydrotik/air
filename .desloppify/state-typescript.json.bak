    "review::.::holistic::error_consistency::dashboard_swallows_server_failures::98c5d049": {
      "id": "review::.::holistic::error_consistency::dashboard_swallows_server_failures::98c5d049",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "The API and dashboard collapse real failures into empty-data states",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "src/server/index.ts",
          "src/dashboard/hooks/useTelemetry.ts",
          "src/dashboard/pages/DashboardPage.tsx"
        ],
        "evidence": [
          "The server returns mixed ad hoc error payloads like `{ error: 'Session not found' }` and `{ ok: false, error: String(err) }` without status-code distinctions in [src/server/index.ts](/Users/donovanadams/Desktop/hydrotik/packages/hy-ai-rum/src/server/index.ts).",
          "Every dashboard fetch helper catches and returns `[]` or a dummy object in [src/dashboard/hooks/useTelemetry.ts](/Users/donovanadams/Desktop/hydrotik/packages/hy-ai-rum/src/dashboard/hooks/useTelemetry.ts), so missing resources, parse failures, and transport errors all look identical to the UI.",
          "`DashboardPage` uses those fallbacks as if they were authoritative empty datasets, which turns real server failures into silent empty panels in [src/dashboard/pages/DashboardPage.tsx](/Users/donovanadams/Desktop/hydrotik/packages/hy-ai-rum/src/dashboard/pages/DashboardPage.tsx)."
        ],
        "suggestion": "Standardize the API on explicit HTTP status codes plus one error envelope shape, and have `useTelemetry()` surface `{ data, error, loading }` per resource instead of converting failures into empty arrays. That lets panels render true empty states only when the request succeeded with no data.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-02T01:44:24+00:00",
      "last_seen": "2026-03-02T01:44:24+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "typescript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
