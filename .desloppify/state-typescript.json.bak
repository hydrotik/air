    "review::.::holistic::error_consistency::silent_dashboard_transport_failures::0375bfbf": {
      "id": "review::.::holistic::error_consistency::silent_dashboard_transport_failures::0375bfbf",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "The dashboard hook swallows transport and parsing failures, turning backend faults into empty-but-valid data.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "src/dashboard/hooks/useTelemetry.ts",
          "src/server/start.ts"
        ],
        "evidence": [
          "`useTelemetry` ignores malformed WebSocket payloads with a bare `catch` in `ws.onmessage` (lines 24-36).",
          "Every REST helper in `useTelemetry` catches broadly and returns default values like `[]` or `{ segments: [] }` without checking `res.ok` (for example lines 51-75, 77-147, 151-261).",
          "`start.ts` logs startup failures and exits at lines 14-16, so the server boundary is fail-fast while the client boundary is fail-silent for the same subsystem."
        ],
        "suggestion": "Introduce a shared dashboard request helper that checks `res.ok`, preserves the original error, and returns a typed `{ data, error }` or raises a domain-specific error. Keep fallback defaults only at the final rendering boundary, and surface WebSocket parse failures through logging or explicit connection/error state.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-02T01:44:24+00:00",
      "last_seen": "2026-03-02T01:44:24+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "typescript",
      "suppressed": false,
