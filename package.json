{
  "name": "@hydrotik/air",
  "version": "0.1.0",
  "description": "Real-time AI observability — monitor context windows, tool calls, token costs, and compaction for coding agents.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "air": "dist/server/cli.js",
    "air-install-claude-code": "src/collectors/claude-code/install.js",
    "air-codex-watcher": "src/collectors/codex/watcher.js"
  },
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "require": "./dist/sdk/index.cjs"
    },
    "./server": {
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "scripts",
    "src/collectors",
    "README.md",
    "INTEGRATION_PROMPT_README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "observability",
    "rum",
    "telemetry",
    "mcp",
    "rag",
    "llm",
    "coding-agent",
    "context-window",
    "token-usage",
    "claude",
    "codex",
    "pi",
    "dashboard",
    "drift-detection",
    "cost-tracking"
  ],
  "homepage": "https://github.com/hydrotik/air#readme",
  "bugs": {
    "url": "https://github.com/hydrotik/air/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hydrotik/air.git"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:dashboard\"",
    "dev:server": "tsx watch src/server/start.ts",
    "dev:dashboard": "vite",
    "build": "rimraf dist && tsup && vite build",
    "build:server": "tsup",
    "build:dashboard": "vite build",
    "preview": "vite preview",
    "start": "node dist/server/cli.js",
    "start:detached": "node scripts/start-detached.mjs",
    "stop": "node scripts/start-detached.mjs --stop",
    "test": "jest --config jest.config.mjs",
    "test:watch": "jest --config jest.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@hydrotik/design-system": "workspace:*",
    "@hydrotik/theme-provider": "workspace:*",
    "@hydrotik/tokens": "workspace:*",
    "@hydrotik/typescript-config": "workspace:*",
    "@sinclair/typebox": "^0.34.33",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "@vanilla-extract/babel-plugin": "^1.2.0",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/vite-plugin": "^4.0.20",
    "@vitejs/plugin-react": "^4.5.2",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.1.2",
    "d3": "^7.9.0",
    "jest": "^30.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
