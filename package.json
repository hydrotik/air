{
  "name": "hydrotik",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "turbo": "turbo",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yaml,yml}\" --ignore-path .gitignore",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e": "turbo run e2e",
    "storybook": "turbo run storybook --filter=@hydrotik/storybook",
    "build-storybook": "turbo run build-storybook --filter=@hydrotik/storybook",
    "prepare": "husky",
    "llm:registry": "hy-ai registry",
    "llm:validate": "hy-ai validate",
    "llm:check": "hy-ai all",
    "llm:all": "hy-ai salt --fetch && hy-ai registry && hy-ai validate",
    "llm:init": "hy-ai init",
    "capture": "npx tsx scripts/visual-capture.ts",
    "capture:all": "npx tsx scripts/visual-capture.ts --all",
    "capture:editorial": "npx tsx scripts/visual-capture.ts --route /editorial --full-page"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@hydrotik/prettify-config": "workspace:^",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.11",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.6",
    "react-window": "^2.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm exec eslint --fix",
      "pnpm exec prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "pnpm exec prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "pnpm exec prettier --write"
    ]
  }
}
