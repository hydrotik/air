{
  "name": "@hydrotik/config",
  "version": "0.1.0",
  "description": "Cross-project configuration for the Hydrotik monorepo",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ports": {
      "types": "./src/ports.ts",
      "require": "./ports.cjs",
      "default": "./ports.cjs"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
