{
  "name": "@hydrotik/air",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./sdk": "./src/sdk/index.ts",
    "./collector": "./src/collector/index.ts",
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:dashboard\"",
    "dev:server": "tsx watch src/server/start.ts",
    "dev:dashboard": "vite",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "@hydrotik/config": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@hydrotik/design-system": "workspace:*",
    "@hydrotik/theme-provider": "workspace:*",
    "@hydrotik/tokens": "workspace:*",
    "@hydrotik/typescript-config": "workspace:*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "^0.34.33",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.14",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/vite-plugin": "^4.0.20",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "d3": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
